{
  "version": 2,
  "builds": [
    { "src": "api/*.py", "use": "@vercel/python" },
    { "src": "static/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/auth", "dest": "/api/auth.py" },
    { "src": "/api/callback", "dest": "/api/callback.py" },
    { "src": "/", "dest": "/static/index.html" },
    { "src": "/verify", "dest": "/static/verify.html" }
  ]
}
