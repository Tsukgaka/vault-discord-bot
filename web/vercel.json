{
  "version": 2,
  "builds": [
    { "src": "api/auth.py", "use": "@vercel/python" },
    { "src": "api/callback.py", "use": "@vercel/python" },
    { "src": "static/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/auth", "dest": "/api/auth.py" },
    { "src": "/api/callback", "dest": "/api/callback.py" },
    { "src": "/(.*)", "dest": "/static/$1" }
  ]
}
